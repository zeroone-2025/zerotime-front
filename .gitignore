# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.sample

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# verified-links 생성물 — 실제 서명 신원으로 빌드 시점에 생성한다 (커밋 금지, runbook 참조)
/public/.well-known/

# PWA auto-generated files
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/swe-worker-*.js.omc/

# AI 에이전트 worktree (git-conventions 참조)
.worktrees/

# 에이전트 세션 도구 상태
.sisyphus/
